{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs pnpx eslint --fix"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs pnpx prettier --write"
          }
        ]
      }
    ]
  }
}
