{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "paths": {
      "@workspace/auth/*": ["./src/*"],
      "@workspace/db": ["../db/src/index.ts"],
      "@workspace/db/*": ["../db/src/*"],
      "@workspace/email": ["../email/src/index.ts"],
      "@workspace/email/*": ["../email/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vitest.config.ts",
    "eslint.config.ts"
  ]
}
