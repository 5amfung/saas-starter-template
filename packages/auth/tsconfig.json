{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["vitest/globals"],
    "paths": {
      "@workspace/auth/*": ["./src/*"],
      "@workspace/db": ["../db/src/index.ts"],
      "@workspace/db/*": ["../db/src/*"],
      "@workspace/email": ["../email/src/index.ts"],
      "@workspace/email/*": ["../email/src/*"],
      "@workspace/logging/client": ["../logging/src/client.ts"],
      "@workspace/logging/server": ["../logging/src/server.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    "vitest.config.ts",
    "eslint.config.ts"
  ]
}
