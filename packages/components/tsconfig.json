{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/auth": ["../../packages/auth/src/index.ts"],
      "@workspace/auth/*": ["../../packages/auth/src/*"],
      "@workspace/logging/operations": [
        "../../packages/logging/src/operations.ts"
      ],
      "@workspace/logging/redaction": [
        "../../packages/logging/src/redaction.ts"
      ]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "eslint.config.ts"],
  "exclude": ["node_modules"]
}
