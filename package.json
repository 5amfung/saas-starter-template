{
  "name": "sass-starter-template",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint",
    "format": "prettier --write ./src",
    "gen-auth-schema": "pnpx @better-auth/cli generate --config ./src/auth/auth.server.ts --output ./src/db/auth.schema.ts --yes && node --experimental-strip-types scripts/patch-auth-schema.ts && eslint --fix ./src/db/auth.schema.ts && prettier --write ./src/db/auth.schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "email:dev": "bunx react-email dev --dir src/components/email --port 3001",
    "dev:stripe-webhook": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@better-auth/stripe": "^1.5.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@neondatabase/serverless": "^1.0.2",
    "@react-email/components": "^1.0.7",
    "@tabler/icons-react": "^3.36.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/query-broadcast-client-experimental": "5.90.20",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.159.4",
    "@tanstack/react-router-ssr-query": "^1.159.4",
    "@tanstack/react-start": "^1.159.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.159.4",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "nitro": "^3.0.1-alpha.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "2.15.4",
    "resend": "^6.9.2",
    "shadcn": "^3.8.4",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.8",
    "@tanstack/devtools-vite": "^0.5.1",
    "@tanstack/eslint-config": "^0.3.4",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@tanstack/eslint-plugin-router": "^1.155.0",
    "@tanstack/react-devtools": "^0.9.5",
    "@tanstack/react-form-devtools": "^0.2.13",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router-devtools": "^1.159.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.9",
    "eslint-plugin-import-x": "^4.16.2",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "react-email": "^5.2.8",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.0",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
}
