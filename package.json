{
  "name": "saas-starter-template",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/5amfung/saas-starter-template.git"
  },
  "bugs": {
    "url": "https://github.com/5amfung/saas-starter-template/issues"
  },
  "homepage": "https://github.com/5amfung/saas-starter-template#readme",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev dev:stripe-webhook --filter @workspace/web --filter @workspace/admin-web",
    "dev:admin": "pnpm --filter @workspace/admin-web dev",
    "dev:api": "pnpm --filter @workspace/api-server dev",
    "dev:web": "turbo run dev dev:stripe-webhook --filter @workspace/web",
    "build": "turbo run build",
    "start:admin": "pnpm --filter @workspace/admin-web start",
    "start:api": "pnpm --filter @workspace/api-server start",
    "start:web": "pnpm --filter @workspace/web start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check:boundaries": "depcruise --config .dependency-cruiser.cjs apps/web/src apps/admin/src --output-type err",
    "typecheck": "turbo run typecheck",
    "check": "pnpm run check:boundaries && turbo run lint typecheck",
    "format": "turbo run format",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "coverage": "turbo run coverage",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:admin": "pnpm --filter @workspace/admin-web test:e2e",
    "test:e2e:ui:admin": "pnpm --filter @workspace/admin-web test:e2e:ui",
    "test:e2e:report:admin": "pnpm --filter @workspace/admin-web test:e2e:report",
    "test:e2e:web": "pnpm --filter @workspace/web test:e2e",
    "test:e2e:ui:web": "pnpm --filter @workspace/web test:e2e:ui",
    "test:e2e:report:web": "pnpm --filter @workspace/web test:e2e:report",
    "prepare": "husky || echo 'Skip installing husky'",
    "clean": "npkill"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.2.0",
    "@workspace/eslint-config": "workspace:*",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npkill": "^0.12.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,mdx}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@sentry/cli",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@noble/ciphers": "^2.1.1"
    },
    "ignoredBuiltDependencies": []
  },
  "engines": {
    "node": ">=20"
  }
}
