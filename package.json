{
  "name": "saas-starter-template",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev",
    "web:dev": "pnpm --filter ./apps/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "check": "turbo run check",
    "format": "turbo run format",
    "test": "turbo run test",
    "prepare": "husky || echo 'Skip installing husky'",
    "clean": "npkill",
    "db:generate": "pnpm --filter @workspace/db db:generate",
    "db:migrate": "pnpm --filter @workspace/db db:migrate",
    "db:push": "pnpm --filter @workspace/db db:push",
    "db:studio": "pnpm --filter @workspace/db db:studio",
    "gen-auth-schema": "pnpm --filter @workspace/db gen-auth-schema",
    "dev:stripe-webhook": "pnpm --filter @workspace/web dev:stripe-webhook"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "npkill": "^0.12.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,mdx}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@noble/ciphers": "^2.1.1"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
