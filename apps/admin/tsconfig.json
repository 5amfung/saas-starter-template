{
  "extends": "../../tsconfig.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "eslint.config.js",
    "prettier.config.js",
    "vite.config.js"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/email": ["../../packages/email/src/index.ts"],
      "@workspace/email/*": ["../../packages/email/src/*"],
      "@workspace/components/*": ["../../packages/components/src/*/index.ts"],
      "@workspace/logging": ["../../packages/logging/src/logger.ts"],
      "@workspace/logging/server": [
        "../../packages/logging/src/request-logger.server.ts"
      ],
      "@workspace/test-utils": ["../../packages/test-utils/src/index.ts"]
    }
  }
}
