{
  "extends": "../../tsconfig.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "eslint.config.js",
    "prettier.config.js",
    "vite.config.js",
    "src/routes/test-sentry.tss"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/db": ["../../packages/db/src/index.ts"],
      "@workspace/db/*": ["../../packages/db/src/*"],
      "@workspace/email": ["../../packages/email/src/index.ts"],
      "@workspace/email/*": ["../../packages/email/src/*"],
      "@workspace/auth": ["../../packages/auth/src/index.ts"],
      "@workspace/auth/*": ["../../packages/auth/src/*"],
      "@workspace/components/*": ["../../packages/components/src/*/index.ts"],
      "@workspace/policy": ["../../packages/policy/src/index.ts"],
      "@workspace/logging": ["../../packages/logging/src/server.ts"],
      "@workspace/logging/client": ["../../packages/logging/src/client.ts"],
      "@workspace/logging/server": ["../../packages/logging/src/server.ts"],
      "@workspace/test-utils": ["../../packages/test-utils/src/index.ts"]
    }
  }
}
