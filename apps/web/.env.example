VITE_APP_NAME=<your-app-name>

DATABASE_URL='postgresql://[user]:[password]@[neon_hostname]/[dbname]?sslmode=require'

BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-32>
BETTER_AUTH_URL=http://localhost:3000
WORKSPACE_SECRET_ENCRYPTION_KEY=<generate-with-openssl-rand-base64-32>
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM_EMAIL="YourApp <no-reply@mail.yourdomain.com>"
RESEND_REPLY_TO_EMAIL="YourApp <reply-to@yourdomain.com> or optional if same as RESEND_FROM_EMAIL"

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Runtime Sentry DSNs for browser and server
VITE_SENTRY_DSN=
SENTRY_DSN=
# Build-time source map upload (set in Railway/CI for production builds)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
