{
  "name": "@workspace/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
    "dev:stripe-webhook": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook",
    "build": "vite build && cp instrument.server.mjs .output/server",
    "build:e2e": "E2E_MOCK_EMAIL=true VITE_DISABLE_SENTRY=true vite build && cp instrument.server.mjs .output/server",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run --dir test/unit",
    "test:integration": "vitest run --dir test/integration",
    "test:e2e": "pnpm run build:e2e && playwright test",
    "test:e2e:ui": "pnpm run build:e2e && playwright test --ui",
    "test:e2e:chromium": "pnpm run build:e2e && playwright test --project=chromium",
    "test:e2e:firefox": "pnpm run build:e2e && playwright test --project=firefox",
    "test:e2e:webkit": "pnpm run build:e2e && playwright test --project=webkit",
    "test:e2e:report": "playwright show-report",
    "coverage": "vitest run --coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint",
    "format": "prettier --write ./src"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@better-auth/api-key": "1.6.3",
    "@better-auth/stripe": "1.6.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@sentry/tanstackstart-react": "^10.48.0",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/query-broadcast-client-experimental": "^5.96.1",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-ssr-query": "^1.166.10",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.167.12",
    "@workspace/auth": "workspace:*",
    "@workspace/billing": "workspace:*",
    "@workspace/components": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/db-schema": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/integrations": "workspace:*",
    "@workspace/logging": "workspace:*",
    "@workspace/policy": "workspace:*",
    "@workspace/ui": "workspace:*",
    "better-auth": "1.6.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "nitro": "3.0.1-alpha.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "3.8.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tanstack/devtools-vite": "^0.5.5",
    "@tanstack/react-devtools": "^0.9.13",
    "@tanstack/react-form-devtools": "^0.2.20",
    "@tanstack/react-query-devtools": "^5.96.1",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/test-utils": "workspace:*",
    "jsdom": "^28.1.0",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "web-vitals": "^5.2.0"
  }
}
