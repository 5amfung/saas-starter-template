# App name. Shows up in sign in page and email.
VITE_APP_NAME='Acme Inc.'

# Connection string to database.
DATABASE_URL=

# Secret for encryption.
BETTER_AUTH_SECRET=
# URL for APIs.
BETTER_AUTH_URL=http://localhost:3000

# Secret for encrypting workspace-owned API keys.
WORKSPACE_SECRET_ENCRYPTION_KEY=

# Sign-in with Google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend integration for sending email.
RESEND_API_KEY=
RESEND_FROM_EMAIL='Acme Inc<no-reply@mail.example.com>'
RESEND_REPLY_TO_EMAIL='support@example.com'

# Stripe integration.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Runtime Sentry DSN for browser and server.
VITE_SENTRY_DSN=
# Build-time source map upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
